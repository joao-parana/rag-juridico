# USE_OLLAMA = True para rodar localmente com Ollama (llama3.2 + nomic-embed-text).
# Neste caso, OPENAI_KEY, EMBEDDINGS_MODEL e LLM_MODEL são ignorados.
USE_OLLAMA = False

OPENAI_KEY = 123456789
DATA_PATH = dados

CDC_PATH = ${DATA_PATH}/cdc.pdf
LGPD_PATH = ${DATA_PATH}/lgpd.pdf
CHROMA_DB_PATH = ${DATA_PATH}/chroma_db

EMBEDDINGS_MODEL = text-embedding-3-small
LLM_MODEL = gpt-5-mini

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<SUA_API_KEY>
LANGSMITH_PROJECT=<SEU_PROJETO>